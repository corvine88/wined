{
  "expo": {
    "name": "ViBiCo",
    "slug": "wined",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wined",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wined.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Scatta foto delle tue bottiglie di vino",
        "NSPhotoLibraryUsageDescription": "Scegli foto delle bottiglie dalla galleria",
        "NSLocationWhenInUseUsageDescription": "Salva il luogo delle tue degustazioni"
      }
    },
    "android": {
      "package": "com.wined.app",
      "versionCode": 6,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#365959"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCC2q2B2J6lZGEGvYz3LrAC-CJm2V10RAM"
        }
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "mimeType": "application/octet-stream",
              "pathPattern": ".*\\.vibico"
            },
            {
              "mimeType": "application/json",
              "pathPattern": ".*\\.vibico"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Scegli foto delle bottiglie dalla galleria",
          "cameraPermission": "Scatta foto delle tue bottiglie di vino"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Salva il luogo delle tue degustazioni"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F9F8F5"
        }
      ],
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "13782cd0-3777-4c55-a547-0328228e9caf"
      }
    },
    "owner": "serena88"
  }
}
