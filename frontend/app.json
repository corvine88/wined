{
  "expo": {
    "name": "Diario del Vino",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "diariodelvino",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scatta foto delle tue bottiglie di vino",
        "NSPhotoLibraryUsageDescription": "Scegli foto delle bottiglie dalla galleria",
        "NSLocationWhenInUseUsageDescription": "Salva il luogo delle tue degustazioni"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#7B2E40"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Scegli foto delle bottiglie dalla galleria",
          "cameraPermission": "Scatta foto delle tue bottiglie di vino"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Salva il luogo delle tue degustazioni"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F9F8F5"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
